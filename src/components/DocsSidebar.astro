---
import { getCollection } from "astro:content";
import Search from "astro-pagefind/components/Search";

const docs = await getCollection("docs", ({ data }) => !data.draft);

// Group docs by section
const sections = docs.reduce(
    (acc, doc) => {
        const section = doc.data.section || "Other";
        if (!acc[section]) {
            acc[section] = [];
        }
        acc[section].push(doc);
        return acc;
    },
    {} as Record<string, typeof docs>,
);

// Sort docs within each section by order
Object.keys(sections).forEach((section) => {
    sections[section].sort(
        (a, b) => (a.data.order || 999) - (b.data.order || 999),
    );
});

// Define section order
const sectionOrder = [
    "Overview",
    "Runtara Platform",
    "Durable Execution",
    "Distributed Durable Execution",
    "Managed Runtime Environments",
    "Durable Workflows",
    "Step Types",
    "Agents",
    "Examples",
    "Guides",
    "Other",
];
const orderedSections = sectionOrder.filter((s) => sections[s]);

const currentPath = Astro.url.pathname;
---

<aside class="docs-sidebar" id="docs-sidebar">
    <div class="sidebar-search" id="docs-search">
        <Search
            showImages={false}
            showSubResults={true}
            placeholder="Search docs..."
        />
        <div class="search-shortcut">
            <kbd>Cmd</kbd><span>+</span><kbd>K</kbd>
        </div>
    </div>

    <nav class="sidebar-nav">
        {
            orderedSections.map((section) => (
                <div class="nav-section">
                    <h3 class="nav-section-title">{section}</h3>
                    <ul class="nav-list">
                        {sections[section].map((doc) => (
                            <li>
                                <a
                                    href={`/docs/${doc.id}`}
                                    class:list={[
                                        {
                                            active:
                                                currentPath ===
                                                    `/docs/${doc.id}` ||
                                                currentPath ===
                                                    `/docs/${doc.id}.html`,
                                        },
                                    ]}
                                >
                                    {doc.data.title}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            ))
        }
    </nav>
</aside>

<script>
    // Cmd+K / Ctrl+K keyboard shortcut for search
    document.addEventListener("keydown", (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
            e.preventDefault();
            const searchInput = document.querySelector(
                "#docs-search input",
            ) as HTMLInputElement;
            if (searchInput) {
                searchInput.focus();
            }
        }
    });

    // Mobile sidebar toggle
    const mobileMenuBtn = document.querySelector(".mobile-menu-btn");
    const sidebar = document.querySelector("#docs-sidebar");

    mobileMenuBtn?.addEventListener("click", () => {
        sidebar?.classList.toggle("open");
    });

    // Close sidebar when clicking a link on mobile
    const sidebarLinks = document.querySelectorAll(".sidebar-nav a");
    sidebarLinks.forEach((link) => {
        link.addEventListener("click", () => {
            if (window.innerWidth <= 768) {
                sidebar?.classList.remove("open");
            }
        });
    });
</script>

<style>
    .docs-sidebar {
        position: fixed;
        top: 57px;
        left: 0;
        bottom: 0;
        width: 280px;
        background: var(--color-bg-secondary);
        border-right: 1px solid var(--color-border);
        overflow-y: auto;
        padding: 1.5rem;
        z-index: 50;
    }

    .sidebar-search {
        margin-bottom: 1.5rem;
    }

    .search-shortcut {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
        margin-top: 0.5rem;
        font-size: 0.75rem;
        color: var(--color-text-muted);
    }

    .search-shortcut kbd {
        background: var(--color-bg-tertiary);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        color: var(--color-text-secondary);
        padding: 0.125rem 0.375rem;
        font-family: inherit;
        font-size: 0.625rem;
    }

    .sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .nav-section-title {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-text-muted);
        margin-bottom: 0.75rem;
    }

    .nav-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .nav-list a {
        display: block;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        color: var(--color-text-secondary);
        text-decoration: none;
        border-radius: 6px;
        transition: all 0.15s;
    }

    .nav-list a:hover {
        color: var(--color-text-primary);
        background: var(--color-bg-tertiary);
    }

    .nav-list a.active {
        color: var(--color-accent);
        background: rgba(34, 211, 238, 0.1);
    }

    @media (max-width: 768px) {
        .docs-sidebar {
            transform: translateX(-100%);
            transition: transform 0.3s ease;
            width: 100%;
            max-width: 320px;
        }

        .docs-sidebar.open {
            transform: translateX(0);
        }

        .search-shortcut {
            display: none;
        }
    }
</style>
