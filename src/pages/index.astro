---
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import SiteFooter from "../components/SiteFooter.astro";

const githubUrl = "https://github.com/runtarahq/runtara";
const cloudUrl = "https://tally.so/r/81qE5o";

const showcasePanels = [
    {
        title: "Workflow workspace",
        body: "Organize automations by operational area and keep builders focused on the process they own.",
        image: "/showcase/images/01-workflows-organized-operations.png",
        alt: "Runtara workflow workspace organized by business area",
    },
    {
        title: "Trigger catalog",
        body: "Start workflows from schedules, HTTP calls, and event-driven entry points without duplicating logic.",
        image: "/showcase/images/03-trigger-automation-catalog.png",
        alt: "Runtara trigger automation catalog",
    },
    {
        title: "Connections",
        body: "Manage provider credentials, storage targets, and shared integrations outside workflow definitions.",
        image: "/showcase/images/04-integration-connections.png",
        alt: "Runtara integration connections catalog",
    },
];

const capabilityRows = [
    {
        title: "Sandboxed agent runs",
        body: "Workflow logic executes inside WebAssembly isolation with no raw filesystem, network, or credential access.",
    },
    {
        title: "Credential mediation",
        body: "Connections stay server-side. The runtime injects credentials at the host boundary instead of exposing secrets to agents.",
    },
    {
        title: "Durable checkpoints",
        body: "Long-running agent loops checkpoint after tool calls, resume after crashes, and avoid replaying completed work.",
    },
    {
        title: "Operational visibility",
        body: "Reports, invocation history, analytics, files, and object data give teams a live surface for production automation.",
    },
];
---

<BaseLayout
    title="Runtara - End-to-End AI Automation"
    description="Runtara Platform combines secure AI workflow automation, integrations, durable execution, reports, analytics, and operational data in one product."
>
    <div class="grid-bg"></div>
    <div class="orb"></div>
    <div class="orb orb-2"></div>

    <div class="container">
        <header>
            <a href="/" class="logo"
                ><img
                    src="/runtara-final.svg"
                    alt="Runtara"
                    class="logo-img"
                /></a
            >
            <div class="header-right">
                <a href="/pricing" class="header-docs">Pricing</a>
                <a href="/docs" class="header-docs">Docs</a>
                <a href={githubUrl} class="header-github" aria-label="GitHub">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                        ></path>
                    </svg>
                </a>
                <ThemeToggle />
            </div>
        </header>
    </div>

    <main class="landing">
        <section class="visual-hero">
            <div class="container hero-content">
                <h1 class="fade-in fade-in-delay-1">
                    Secure AI automation from workflow design to live
                    operations.
                </h1>
                <p class="hero-sub fade-in fade-in-delay-2">
                    Runtara Platform brings AI workflows, triggers, connections,
                    operational data, reports, and execution history into one
                    durable automation surface.
                </p>
                <div class="cta-group fade-in fade-in-delay-3">
                    <a href={cloudUrl} class="btn btn-primary">Runtara Cloud</a>
                    <a href="/docs/runtara-platform" class="btn btn-secondary"
                        >Documentation</a
                    >
                    <a href={githubUrl} class="btn btn-ghost">
                        <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                        >
                            <path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                            ></path>
                        </svg>
                        Source code
                    </a>
                </div>
                <div
                    class="hero-proof fade-in fade-in-delay-3"
                    aria-label="Runtara product coverage"
                >
                    <span>Workflows</span>
                    <span>Triggers</span>
                    <span>Connections</span>
                    <span>Reports</span>
                    <span>Analytics</span>
                </div>
            </div>
            <div class="hero-screen" aria-hidden="true">
                <img
                    src="/showcase/images/hero-workflow-builder-crop.png"
                    alt=""
                    loading="eager"
                    decoding="async"
                />
            </div>
        </section>

        <section class="product-overview" data-reveal>
            <div class="container">
                <div class="section-heading">
                    <h2>
                        One workspace for building and operating AI automations.
                    </h2>
                    <p>
                        Runtara is not just a workflow runner. It gives teams
                        the product surface around automation: reusable
                        integrations, structured data, report publishing, file
                        handling, and execution observability.
                    </p>
                </div>
                <div class="panel-row">
                    {
                        showcasePanels.map((panel) => (
                            <article class="screenshot-panel">
                                <img
                                    src={panel.image}
                                    alt={panel.alt}
                                    loading="lazy"
                                    decoding="async"
                                />
                                <div>
                                    <h3>{panel.title}</h3>
                                    <p>{panel.body}</p>
                                </div>
                            </article>
                        ))
                    }
                </div>
            </div>
        </section>

        <section class="feature-showcase feature-showcase-large" data-reveal>
            <div class="container showcase-grid">
                <div class="showcase-copy">
                    <h2>
                        Build workflows as operational systems, not prompt
                        chains.
                    </h2>
                    <p>
                        Use timeline and canvas views to design agent steps,
                        transformations, child workflows, waits, and completion
                        paths. Problems, versions, and history stay close to the
                        workflow definition.
                    </p>
                    <ul>
                        <li>
                            Readable workflow structure for builders and
                            operators
                        </li>
                        <li>
                            Manual, chat, scheduled, HTTP, and event-driven
                            starts
                        </li>
                        <li>
                            Validation before production triggers depend on the
                            workflow
                        </li>
                    </ul>
                </div>
                <figure class="media-frame">
                    <img
                        src="/showcase/images/02-workflow-timeline-builder.png"
                        alt="Runtara workflow timeline builder"
                        loading="lazy"
                        decoding="async"
                    />
                </figure>
            </div>
        </section>

        <section class="feature-showcase connected-systems" data-reveal>
            <div class="container connected-systems-layout">
                <div class="showcase-copy">
                    <h2>Connect agents to the data and systems they need.</h2>
                    <p>
                        Model operational records inside Runtara, attach
                        external providers through connections, and keep
                        credentials out of workflow definitions.
                    </p>
                    <ul>
                        <li>
                            Object records for catalogs, inventory, suppliers,
                            and support knowledge
                        </li>
                        <li>
                            Provider connections for OpenAI, Slack, Shopify,
                            storage, and more
                        </li>
                        <li>
                            Default file storage and shared connection
                            governance
                        </li>
                    </ul>
                </div>
                <div class="media-stack">
                    <figure class="media-frame">
                        <img
                            src="/showcase/images/05-object-model-records.png"
                            alt="Runtara object model records"
                            loading="lazy"
                            decoding="async"
                        />
                    </figure>
                    <figure class="media-frame media-frame-small">
                        <img
                            src="/showcase/images/04-integration-connections.png"
                            alt="Runtara provider connections"
                            loading="lazy"
                            decoding="async"
                        />
                    </figure>
                </div>
            </div>
        </section>

        <section class="feature-showcase" data-reveal>
            <div class="container showcase-grid">
                <div class="showcase-copy">
                    <h2>
                        Turn automation outputs into reports people can use.
                    </h2>
                    <p>
                        Publish operational reports with narrative text,
                        metrics, charts, tables, and reusable report definitions
                        backed by Runtara object data.
                    </p>
                    <ul>
                        <li>Report gallery for operators and stakeholders</li>
                        <li>Chart, table, metric, and Markdown blocks</li>
                        <li>
                            Editable report definitions with schema-backed
                            datasets
                        </li>
                    </ul>
                </div>
                <figure class="media-frame">
                    <img
                        src="/showcase/images/07-category-performance-dashboard.png"
                        alt="Runtara category performance dashboard"
                        loading="lazy"
                        decoding="async"
                    />
                </figure>
            </div>
        </section>

        <section class="operations-strip" data-reveal>
            <div class="container">
                <div class="section-heading">
                    <h2>
                        Know what ran, what changed, and where attention is
                        needed.
                    </h2>
                    <p>
                        Invocation history and analytics give operators a live
                        view of workflow health, usage, rate limits, and
                        execution trends.
                    </p>
                </div>
                <div class="ops-media-grid">
                    <figure class="media-frame">
                        <img
                            src="/showcase/images/09-invocation-history.png"
                            alt="Runtara invocation history"
                            loading="lazy"
                            decoding="async"
                        />
                    </figure>
                    <figure class="media-frame">
                        <img
                            src="/showcase/images/10-usage-analytics.png"
                            alt="Runtara usage analytics"
                            loading="lazy"
                            decoding="async"
                        />
                    </figure>
                </div>
            </div>
        </section>

        <section class="security-section" data-reveal>
            <div class="container security-layout">
                <div>
                    <h2>Secure by runtime design.</h2>
                    <p>
                        Runtara combines a product surface for builders with
                        runtime primitives for secure, durable AI automation.
                    </p>
                </div>
                <div class="capability-list">
                    {
                        capabilityRows.map((row) => (
                            <article class="capability-row">
                                <h3>{row.title}</h3>
                                <p>{row.body}</p>
                            </article>
                        ))
                    }
                </div>
            </div>
        </section>

        <section class="final-cta visual-final" data-reveal>
            <div class="container">
                <h2>Build the automation surface your agents need.</h2>
                <p>
                    Start with the Runtara Platform user guide, then connect
                    workflows, data, reports, and operations in one place.
                </p>
                <div class="cta-group">
                    <a href="/docs/runtara-platform" class="btn btn-primary"
                        >Read the user guide</a
                    >
                    <a href={cloudUrl} class="btn btn-secondary"
                        >Runtara Cloud</a
                    >
                </div>
            </div>
        </section>

        <SiteFooter />
    </main>

    <script>
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("revealed");
                        observer.unobserve(entry.target);
                    }
                });
            },
            { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
        );

        document
            .querySelectorAll("[data-reveal]")
            .forEach((el) => observer.observe(el));
    </script>
</BaseLayout>
